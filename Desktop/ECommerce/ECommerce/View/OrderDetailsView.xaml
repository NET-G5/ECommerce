<Window x:Class="ECommerce.View.OrderDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ECommerce.View"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DesignHeight="600"
        d:DesignWidth="800"
        Background="#FF202137"
        WindowState="Maximized"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF2E2F47" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF2E2F47" />
            <Setter Property="RowBackground" Value="#FF2E2F47" />
            <Setter Property="AlternatingRowBackground" Value="#FF2E2F47" />
        </Style>
    </Window.Resources>
    <Grid>
        <Border Padding="10"
                BorderBrush="LightBlue"
                BorderThickness="2"
                CornerRadius="10">
            <StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                </Grid>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>



                    <Button x:Name="btnMinimize"
                            Grid.Column="1"
                            BorderThickness="0"
                            Click="BtnMinimize_Click"
                            Content="-"
                            Cursor="Hand"
                            FontFamily="Montserrat"
                            FontSize="12"
                            Foreground="White">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#28AEED" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2788EF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="25"
                                        Height="25"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="9">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                    <Button x:Name="btnClose"
                            Grid.Column="2"
                            Background="#DA34EA"
                            BorderThickness="0"
                            Click="BtnClose_Click"
                            Content="X"
                            Cursor="Hand"
                            FontFamily="Montserrat"
                            FontSize="12"
                            Foreground="White">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#28AEED" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2788EF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="25"
                                        Height="25"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="9">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>
                <TextBlock Grid.Row="1"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Text="Order Details" />
                <StackPanel Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBox x:Name="id"
                             Grid.Row="2"
                             Width="100"
                             Height="30"
                             Margin="10,0"
                             Padding="5"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             materialDesign:HintAssist.Hint="ID"
                             Background="#FF2E2F47"
                             Foreground="#b0b9c6"
                             IsHitTestVisible="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Visibility="Visible" />
                </StackPanel>
                <StackPanel Grid.Row="3"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBox Width="340"
                             Height="30"
                             Padding="5"
                             HorizontalAlignment="Center"
                             materialDesign:HintAssist.Hint="Full Name"
                             Background="#FF2E2F47"
                             Foreground="#b0b9c6"
                             IsHitTestVisible="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </StackPanel>
                <StackPanel Grid.Row="4"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBox Width="150"
                             Height="30"
                             Margin="10,0"
                             Padding="5"
                             materialDesign:HintAssist.Hint="Order Date"
                             Background="#FF2E2F47"
                             Foreground="#b0b9c6"
                             IsHitTestVisible="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    <TextBox Width="150"
                             Height="30"
                             Margin="10,0"
                             Padding="5"
                             materialDesign:HintAssist.Hint="Expire Date"
                             Background="#FF2E2F47"
                             Foreground="#b0b9c6"
                             IsHitTestVisible="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    <TextBox Width="150"
                             Height="30"
                             Margin="10,0"
                             Padding="5"
                             materialDesign:HintAssist.Hint="Total Price"
                             Background="#FF2E2F47"
                             Foreground="#b0b9c6"
                             IsHitTestVisible="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <!--<Button Width="120"
                            Height="30"
                            Margin="10,0"
                            Background="#FF204E"
                            Click="Button_Click_2"
                            Content="Order Cancel"
                            Foreground="White" />-->
                </StackPanel>
                <Grid Background="White">
                    <StackPanel>
                        <ItemsControl x:Name="OrderDetails"
                                      Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="5"
                                            Padding="10"
                                            BorderBrush="Gray"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="1"
                                                        Margin="10">
                                                <TextBlock Text="{Binding Id}" />
                                                <TextBlock FontSize="16"
                                                           FontWeight="Bold"
                                                           Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Description}" />
                                                <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}" />
                                                <Button Margin="5,5"
                                                        Padding="10,5"
                                                        HorizontalAlignment="Right"
                                                        Background="#4CAF50"
                                                        Content="Refund"
                                                        Foreground="White" /> 
                                                <Button Margin="5,5"
                                                        Padding="10,5"
                                                        HorizontalAlignment="Right"
                                                        Background="#FF204E"
                                                        Content="Cencel"
                                                        Foreground="White" />
                                                <Button Margin="5,5"
                                                        Padding="23,5"
                                                        HorizontalAlignment="Right"
                                                        Background="#4CAF50"
                                                        Content="Sale"
                                                        Foreground="White" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Margin="10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Margin="5"
                                    Padding="10,5"
                                    Background="#FF204E"
                                    Content="Order Cancel"
                                    Foreground="White" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <!--<DataGrid Grid.Row="5"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="False"
                          Foreground="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="Id"
                                            Width="*"
                                            Header="Id" />
                        <DataGridTextColumn x:Name="Name"
                                            Width="*"
                                            Header="Name" />
                        <DataGridTextColumn x:Name="Price"
                                            Width="*"
                                            Header="Price" />
                        <DataGridTemplateColumn x:Name="Status"
                            Width="*"
                                                Header="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Background="LightBlue"
                                            Content="Refund"
                                            Foreground="White" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>-->
                <StackPanel Grid.Row="6"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Width="100"
                            Height="40"
                            Margin="10"
                            HorizontalAlignment="Center"
                            Background="#9333ea"
                            Click="Button_Click"
                            Content="Save"
                            Foreground="White" />
                    <Button Width="100"
                            Height="40"
                            Margin="10"
                            HorizontalAlignment="Center"
                            Background="#6a738f"
                            Click="Button_Click_1"
                            Content="Back"
                            Foreground="White" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
